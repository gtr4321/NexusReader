{
  "name": "NexusReader",
  "version": "1.1.0",
  "main": "dist/electron/main.js",
  "scripts": {
    "dev": "concurrently \"npm run dev:renderer\" \"npm run dev:electron\" \"npm run dev:core\"",
    "dev:renderer": "cd renderer && npm run dev",
    "dev:electron": "wait-on http://localhost:3000 && tsc -p electron/tsconfig.json && electron .",
    "dev:core": ".venv\\Scripts\\python.exe run.py",
    "build": "npm run build:renderer && npm run build:electron",
    "build:renderer": "cd renderer && npm run build",
    "build:electron": "tsc -p electron/tsconfig.json && electron-builder",
    "clean": "npx rimraf renderer/out renderer/.next dist release"
  },
  "devDependencies": {
    "@types/electron": "^1.6.10",
    "@types/node": "^20.11.0",
    "concurrently": "^8.2.2",
    "electron": "^28.0.0",
    "electron-builder": "^24.9.1",
    "rimraf": "^5.0.0",
    "typescript": "^5.3.3",
    "wait-on": "^7.2.0"
  },
  "dependencies": {
    "electron-serve": "^3.0.1"
  }
}
